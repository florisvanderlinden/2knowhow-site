          <div class="contact-detail-text">
            <strong>Bel ons</strong>
            <a href="{{ site.phoneHref }}">{{ site.phone }}</a>
          </div>
        </div>
        <div class="contact-detail">
          <div class="contact-detail-icon">&#9993;</div>
          <div class="contact-detail-text">
            <strong>E-mail</strong>
            <a href="mailto:{{ site.email }}">{{ site.email }}</a>
          </div>
        </div>
        <div class="contact-detail">
          <div class="contact-detail-icon">&#9962;</div>
          <div class="contact-detail-text">
            <strong>Kantoor</strong>
            <span>{{ site.address }}</span>
          </div>
        </div>
        <div class="contact-detail">
          <div class="contact-detail-icon">&#9200;</div>
          <div class="contact-detail-text">
            <strong>Bereikbaar</strong>
            <span>{{ site.hours }}</span>
          </div>
        </div>
      </div>
      <div class="contact-response">
        &#9889; We reageren binnen 24 uur op werkdagen
      </div>
    </div>
    <div class="contact-form">
      <h3>Plan een kennismaking</h3>
      <form name="kennismaking" method="POST" data-netlify="true">
        <div class="form-row">
          <div class="form-group">
            <label for="contact-firstname">Voornaam *</label>
            <input type="text" id="contact-firstname" name="voornaam" placeholder="Je voornaam" required>
          </div>
          <div class="form-group">
            <label for="contact-lastname">Achternaam *</label>
            <input type="text" id="contact-lastname" name="achternaam" placeholder="Je achternaam" required>
          </div>
        </div>
        <div class="form-group">
          <label for="contact-email">E-mailadres *</label>
          <input type="email" id="contact-email" name="email" placeholder="naam@organisatie.nl" required>
        </div>
        <div class="form-group">
          <label for="contact-phone">Telefoonnummer</label>
          <input type="tel" id="contact-phone" name="telefoon" placeholder="+31 6 ...">
        </div>
        <div class="form-group">
          <label for="contact-org">Organisatie</label>
          <input type="text" id="contact-org" name="organisatie" placeholder="Naam van je organisatie">
        </div>
        <div class="form-group">
          <label for="contact-sector">Sector</label>
          <select id="contact-sector" name="sector">
            <option value="">Selecteer je sector</option>
            <option value="commercieel">Commercieel / bedrijfsleven</option>
            <option value="zorg">Zorg</option>
            <option value="overheid">Overheid / gemeente</option>
            <option value="onderwijs">Onderwijs</option>
            <option value="woningcorporatie">Woningcorporatie</option>
            <option value="anders">Anders</option>
          </select>
        </div>
        <div class="form-group">
          <label for="contact-message">Waar kunnen we je mee helpen?</label>
          <textarea id="contact-message" name="bericht" placeholder="Beschrijf kort jullie situatie of vraagstuk..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">Verstuur aanvraag &rarr;</button>
        <p style="font-size: 12px; color: var(--2kh-text-muted); margin-top: 12px; text-align: center;">Door te versturen ga je akkoord met ons <a href="/privacybeleid/" style="text-decoration: underline;">privacybeleid</a>.</p>
